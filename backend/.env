FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1

SECRET_KEY=dev-secret-key-change-in-production-abc123xyz
JWT_SECRET_KEY=jwt-secret-key-change-in-production-xyz789
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

DATABASE_URL=sqlite:///moneysaver.db

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://localhost,capacitor://localhost

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/hour

UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
